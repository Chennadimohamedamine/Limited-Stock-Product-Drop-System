{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "testMatch": ["**/*.test.ts"],
  "transform": {
    "^.+\\.tsx?$": "['ts-jest', { tsconfig: 'tsconfig.json' }]",
  },
  "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/server.ts"
  ],
  "coverageDirectory": "coverage",
  "testEnvironmentOptions": {},
  "globals": {
    "ts-jest": {
      "diagnostics": false
    }
  },
  "testTimeout": 120000,
  "setupFiles": ["<rootDir>/tests/setup.ts"]
}
